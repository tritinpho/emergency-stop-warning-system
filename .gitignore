# Claude Code local settings (machine-specific, not for sharing)
.claude/settings.local.json

# OS / editor cruft
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*~
.vscode/
.idea/

# Python (software/ — Level-A harness + SUT)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# PlatformIO (firmware/ — build output + per-machine caches)
.pio/

# K230 detector weights. ACLAB ELMS IP; this repo is PUBLIC. models/README.md tells
# you to place the binaries next to their deploy_config.json, so an accidental
# `git add .` is one command away from publishing them. Storage is still undecided
# (ADR-0016 backlog #7) — if that lands on git-LFS, drop this rule deliberately.
*.kmodel

# Host detector-in-the-loop (software/tools/host_yolo_loop.py): ultralytics downloads
# YOLO weights into the CWD on first use, and capture sessions land in captures/ by
# default. Weights are pinned by SHA-256 in each session's ground_truth.json, never
# by committing them; sessions are evidence, reviewed and archived deliberately.
*.pt
captures/
